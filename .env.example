# Map provider keys will be wired in phase 3.
NEXT_PUBLIC_AMAP_JS_KEY=
NEXT_PUBLIC_AMAP_SECURITY_JS_CODE=
AMAP_WEB_SERVICE_KEY=

# AI provider keys are optional during local fallback development.
NEXT_PUBLIC_DEEPSEEK_PROXY_ENABLED=false
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
AI_DAILY_USER_LIMIT=
AI_PROJECT_COST_LIMIT_CNY=

# Supabase will be wired in phase 2.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only values for Supabase Edge Functions. Never expose these in the browser.
SUPABASE_SERVICE_ROLE_KEY=
SHARE_ALLOWED_ORIGINS=http://localhost:3000,https://999hkkzjvy-cell.github.io
